# Dependencies (installed inside the image)
node_modules/

# Version control
.git/
.gitignore

# Build outputs (rebuilt during docker build)
dist/
docs/assets/

# Local env and secrets
.env
.env.*
!.env.example

# Test and CI artifacts
coverage/
.nyc_output/
cypress/
cypress.config.js
**/*.test.js
**/*.test.jsx
__mocks__/
jest.config.js
jest.setup.js

# Screenshots and debug captures
screenshots/
*.png
!src/assets/**

# Editor and OS junk
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Logs and caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.cache/
.eslintcache

# Documentation (not needed for runtime image)
docs/
*.md
