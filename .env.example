    VITE_DB_ADAPTER=supabase
    VITE_SUPABASE_URL=your-supabase-url
    VITE_SUPABASE_KEY=your-supabase-key

# OpenAI answer provider (server-side only; loaded by askApiPlugin from .env.local)
OPENAI_ANSWER_PROVIDER=fake
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MAX_CONTEXT_TOKENS=2000
# OPENAI_MAX_OUTPUT_TOKENS=800

# Protected AI routes (/api/ask, /api/summary)
CAMP_SCOUT_API_TOKEN=your-internal-api-token
# API_MAX_QUESTION_LENGTH=500
# API_MAX_TOP_DOCUMENT_COUNT=5
# API_MAX_JSON_BODY_BYTES=16384
# API_RATE_LIMIT_ASK_PER_MINUTE=20
