    VITE_DB_ADAPTER=supabase
    VITE_SUPABASE_URL=your-supabase-url
    VITE_SUPABASE_KEY=your-supabase-key

# OpenAI answer provider (server-side only; loaded by askApiPlugin from .env.local)
OPENAI_ANSWER_PROVIDER=fake
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MAX_CONTEXT_TOKENS=2000
# OPENAI_MAX_OUTPUT_TOKENS=800

# AI Operations (server-side only)
AI_ENABLED=false
# AI_MAINTENANCE_MODE=false
# AI_DAILY_REQUEST_LIMIT=500
# AI_DAILY_INPUT_TOKEN_LIMIT=1000000
# AI_DAILY_OUTPUT_TOKEN_LIMIT=500000
# AI_DAILY_DOLLAR_LIMIT=5.00
# AI_HOURLY_REQUEST_LIMIT=100
# AI_HOURLY_TOKEN_LIMIT=200000
# AI_HOURLY_DOLLAR_LIMIT=1.00
# AI_AUDIT_LOG_PATH=.ai-audit/audit-log.jsonl
# AI_AUDIT_LOG_RETENTION_DAYS=30
# AI_INPUT_COST_PER_MILLION=0.15
# AI_OUTPUT_COST_PER_MILLION=0.60

# Stripe donations (server-side only; publishable key is not sent to the client)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_PRICE_5=price_your_5_dollar_price_id
STRIPE_PRICE_10=price_your_10_dollar_price_id
STRIPE_PRICE_25=price_your_25_dollar_price_id
APP_URL=https://campscout.terapak.com
# Local dev: copy this file to .env.local and set real Stripe test keys plus:
# APP_URL=http://localhost:5173

# Protected AI routes (/api/ask, /api/summary)
CAMP_SCOUT_API_TOKEN=your-internal-api-token
# API_MAX_QUESTION_LENGTH=500
# API_MAX_TOP_DOCUMENT_COUNT=5
# API_MAX_JSON_BODY_BYTES=16384
# API_RATE_LIMIT_ASK_PER_MINUTE=20
# API_RATE_LIMIT_SUMMARY_PER_MINUTE=10
